@startuml ClassDiagram_Page2_Part2
top to bottom direction
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false
skinparam defaultFontName Arial
skinparam nodesep 20
skinparam ranksep 50
skinparam packageStyle rectangle
skinparam dpi 150

skinparam class {
  BorderColor #2C3E50
  ArrowColor #2C3E50
  FontColor #1F2937
  BackgroundColor White
  FontSize 9
}

skinparam package<<repository>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontSize 10
}
skinparam package<<service>> {
  BackgroundColor #F3E5F5
  BorderColor #7B1FA2
  FontSize 10
}
skinparam package<<controller>> {
  BackgroundColor #FCE4EC
  BorderColor #C2185B
  FontSize 10
}

' ============ TANG 1: CONTROLLER ============
package "controller (Part 2: Job, CV, Application, Pipeline)" as P_Controller <<controller>> {
  class TinTuyenDungCtrl
  class HoSoCvCtrl
  class ChiTietCvCtrl
  class CvSkillCtrl
  class JobSkillCtrl
  class DonUngTuyenCtrl
  class LichPhongVanCtrl
  class ThongBaoCtrl
  class DashboardCtrl
  class MatchingCtrl
}

' ============ TANG 2: SERVICE ============
package "service (Part 2)" as P_Service <<service>> {
  interface TinTuyenDungSvc
  interface HoSoCvService
  interface ChiTietCvSvc
  interface CvSkillSvc
  interface JobSkillSvc
  interface DonUngTuyenSvc
  interface LichSuTrangThaiSvc
  interface LichPhongVanSvc
  interface ThongBaoSvc
  interface DashboardSvc
  interface MatchingSvc
  interface FileStorageSvc
}

' ============ TANG 3: REPOSITORY ============
package "repository (Part 2)" as P_Repository <<repository>> {
  interface TinTuyenDungRepo
  interface HoSoCvRepo
  interface ChiTietCvRepo
  interface ChiTietKyNangCvRepo
  interface CtKyNangTinRepo
  interface DonUngTuyenRepo
  interface LichSuTrangThaiRepo
  interface LichPhongVanRepo
  interface ThongBaoRepo
  interface MatchingRepo
}

' ============ QUY ĐỊNH BỐ CỤC 3 TẦNG ============
P_Controller -[hidden]down-> P_Service
P_Service -[hidden]down-> P_Repository

' ============ CONTROLLER -> SERVICE ============
TinTuyenDungCtrl --> TinTuyenDungSvc
HoSoCvCtrl --> HoSoCvService
ChiTietCvCtrl --> ChiTietCvSvc
CvSkillCtrl --> CvSkillSvc
JobSkillCtrl --> JobSkillSvc
DonUngTuyenCtrl --> DonUngTuyenSvc
DonUngTuyenCtrl --> LichSuTrangThaiSvc
LichPhongVanCtrl --> LichPhongVanSvc
ThongBaoCtrl --> ThongBaoSvc
DashboardCtrl --> DashboardSvc
MatchingCtrl --> MatchingSvc

' ============ SERVICE -> REPOSITORY ============
TinTuyenDungSvc --> TinTuyenDungRepo
HoSoCvService --> HoSoCvRepo
HoSoCvService -> FileStorageSvc
ChiTietCvSvc --> ChiTietCvRepo
CvSkillSvc --> ChiTietKyNangCvRepo
JobSkillSvc --> CtKyNangTinRepo
DonUngTuyenSvc --> DonUngTuyenRepo
LichSuTrangThaiSvc --> LichSuTrangThaiRepo
LichPhongVanSvc --> LichPhongVanRepo
ThongBaoSvc --> ThongBaoRepo
DashboardSvc --> DonUngTuyenRepo
DashboardSvc --> TinTuyenDungRepo
MatchingSvc --> MatchingRepo

@enduml
