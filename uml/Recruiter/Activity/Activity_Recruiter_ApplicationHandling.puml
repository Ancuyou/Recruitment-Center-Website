@startuml Activity_Recruiter_ApplicationHandling
title Nhà Tuyển Dụng - Xử Lý Đơn Ứng Tuyển

start

:Click "Đơn ứng tuyển";
:Xem danh sách đơn;

:Lọc theo trạng thái / công ty;

:Click vào đơn cần xem;

:Xem thông tin ứng viên;
:Xem điểm phù hợp;

:Xem CV ứng viên;
:Đọc cover letter;

if (Phù hợp?) then (Có)
  :Cập nhật trạng thái → PHONG_VAN;
else (Không)
  :Cập nhật trạng thái → TU_CHOI;
endif

:Ứng viên nhận thông báo cập nhật;

stop

@enduml
