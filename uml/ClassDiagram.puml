@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundcorner 10
skinparam nodesep 50
skinparam ranksep 65
hide empty methods
hide circle

title Recruitment Center - Class Diagram (Simplified Layout)

package "1. Domain Model" {
    package "entity.enums" {
        enum VaiTroTaiKhoan
        enum GioiTinh
        enum CapBacYeuCau
        enum HinhThucLamViec
        enum TrangThaiTin
        enum TrangThaiDon
        enum HinhThucPhongVan
        enum TrangThaiPhongVan
        enum LoaiThongBao
        enum LoaiBanGhi
        enum KhuVucEnum
        enum NganhNgheEnum
    }

    package "entity.id" {
        class ChiTietKyNangCvId {
            - Long hoSoCvId
            - Long kyNangId
        }
    }

    package "entity" {
        class TaiKhoan {
            - Long id
            - String email
            - String matKhauHash
            - VaiTroTaiKhoan vaiTro
            - Boolean laKichHoat
        }

        class UngVien {
            - Long id
            - String hoTen
            - GioiTinh gioiTinh
        }

        class NhaTuyenDung {
            - Long id
            - String hoTen
            - String chucVu
        }

        class CongTy {
            - Long id
            - String tenCongTy
            - String maSoThue
        }

        class TinTuyenDung {
            - Long id
            - String tieuDe
            - TrangThaiTin trangThai
            - CapBacYeuCau capBacYeuCau
            - HinhThucLamViec hinhThucLamViec
        }

        class HoSoCv {
            - Long id
            - String tieuDeCv
            - Boolean laCvChinh
        }

        class ChiTietCv {
            - Long id
            - Integer loaiBanGhi
            - String tenToChuc
        }

        class KyNang {
            - Long id
            - String tenKyNang
        }

        class ChiTietKyNangTin {
            - Long id
            - Integer yeucau
        }

        class ChiTietKyNangCv {
            - ChiTietKyNangCvId id
            - Integer mucThanhThao
        }

        class DonUngTuyen {
            - Long id
            - TrangThaiDon trangThaiHienTai
        }

        class LichSuTrangThai {
            - Long id
            - Integer trangThaiMoi
        }

        class LichPhongVan {
            - Long id
            - String tieuDeVong
            - HinhThucPhongVan hinhThuc
            - TrangThaiPhongVan trangThaiPhongVan
        }

        class ThongBao {
            - Long id
            - String tieuDe
            - LoaiThongBao loaiThongBao
            - Boolean daDoc
        }

        class PendingRegistration {
            - Long id
            - String token
        }

        class PendingPasswordReset {
            - Long id
            - String token
        }
    }
}

package "2. Application Layer" {
    package "controller" as CTRL {
        class AuthController
        class UserController
        class AdminUserController
        class CompanyController
        class TinTuyenDungController
        class HoSoCvController
        class ChiTietCvController
        class CvSkillController
        class JobSkillController
        class DonUngTuyenController
        class LichPhongVanController
        class DashboardController
        class MatchingController
        class SkillsController
        class ThongBaoController
        class NganhNgheController
        class KhuVucController
    }

    package "service" as SVC {
        interface AuthService
        interface RegistrationService
        interface AccountWorkflowService
        interface UserService
        interface AdminUserService
        interface CongTyService
        interface TinTuyenDungService
        interface HoSoCvService
        interface ChiTietCvService
        interface CvSkillService
        interface JobSkillService
        interface DonUngTuyenService
        interface LichSuTrangThaiService
        interface LichPhongVanService
        interface ThongBaoService
        interface DashboardService
        interface MatchingService
        interface KyNangService
        interface FileStorageService
    }

    package "repository" as REP {
        interface TaiKhoanRepository
        interface UngVienRepository
        interface NhaTuyenDungRepository
        interface CongTyRepository
        interface TinTuyenDungRepository
        interface HoSoCvRepository
        interface ChiTietCvRepository
        interface KyNangRepository
        interface CtKyNangTinRepository
        interface ChiTietKyNangCvRepository
        interface DonUngTuyenRepository
        interface LichSuTrangThaiRepository
        interface LichPhongVanRepository
        interface ThongBaoRepository
        interface PendingRegistrationRepository
        interface PendingPasswordResetRepository
        interface MatchingRepository
    }

    package "security" as SEC {
        class SecurityConfig
        class JwtAuthenticationFilter
        class JwtTokenProvider
        class CustomUserDetailsService
        class CustomUserDetails
    }

    package "strategy" as STRAT {
        interface SkillMatchingStrategy
        class CosineSimilarityStrategy
        class KeywordMatchingStrategy
    }

    package "util" as UTIL {
        interface TimeProvider
        class SystemTimeProvider
    }
}

' Domain relationships
TaiKhoan "1" <-- "0..1" UngVien : taiKhoan
TaiKhoan "1" <-- "0..1" NhaTuyenDung : taiKhoan
TaiKhoan "1" <-- "0..1" PendingRegistration : taiKhoan
TaiKhoan "1" <-- "0..1" PendingPasswordReset : taiKhoan
TaiKhoan "1" <-- "0..*" ThongBao : taiKhoan

CongTy "1" <-- "0..*" NhaTuyenDung : congTy
CongTy "1" <-- "0..*" TinTuyenDung : congTy
NhaTuyenDung "1" <-- "0..*" TinTuyenDung : nhaTuyenDung

UngVien "1" <-- "0..*" HoSoCv : ungVien
HoSoCv "1" <-- "0..*" ChiTietCv : hoSoCv
HoSoCv "1" <-- "0..*" ChiTietKyNangCv : hoSoCv
KyNang "1" <-- "0..*" ChiTietKyNangCv : kyNang
ChiTietKyNangCv *-- ChiTietKyNangCvId : embeddedId

TinTuyenDung "1" <-- "0..*" ChiTietKyNangTin : tinTuyenDung
KyNang "1" <-- "0..*" ChiTietKyNangTin : kyNang

TinTuyenDung "1" <-- "0..*" DonUngTuyen : tinTuyenDung
HoSoCv "1" <-- "0..*" DonUngTuyen : hoSoCv
DonUngTuyen "1" <-- "0..*" LichSuTrangThai : donUngTuyen
TaiKhoan "1" <-- "0..*" LichSuTrangThai : nguoiThucHien
DonUngTuyen "1" <-- "0..*" LichPhongVan : donUngTuyen
NhaTuyenDung "1" <-- "0..*" LichPhongVan : nguoiPhongVan

' High-level architecture
CTRL ..> SVC : call
SVC ..> REP : use
SEC ..> REP : account lookup
SVC ..> STRAT : matching algorithm
STRAT ..> UTIL : time source
SEC ..> UTIL : token timestamps

' Key dependencies for quick tracing
AuthController --> AuthService
AuthController --> RegistrationService
AuthController --> AccountWorkflowService
UserController --> UserService
AdminUserController --> AdminUserService
CompanyController --> CongTyService
TinTuyenDungController --> TinTuyenDungService
HoSoCvController --> HoSoCvService
ChiTietCvController --> ChiTietCvService
CvSkillController --> CvSkillService
JobSkillController --> JobSkillService
DonUngTuyenController --> DonUngTuyenService
LichPhongVanController --> LichPhongVanService
DashboardController --> DashboardService
MatchingController --> MatchingService
SkillsController --> KyNangService
ThongBaoController --> ThongBaoService

AuthService --> TaiKhoanRepository
RegistrationService --> PendingRegistrationRepository
AccountWorkflowService --> PendingPasswordResetRepository
CongTyService --> CongTyRepository
TinTuyenDungService --> TinTuyenDungRepository
HoSoCvService --> HoSoCvRepository
ChiTietCvService --> ChiTietCvRepository
CvSkillService --> ChiTietKyNangCvRepository
JobSkillService --> CtKyNangTinRepository
DonUngTuyenService --> DonUngTuyenRepository
LichSuTrangThaiService --> LichSuTrangThaiRepository
LichPhongVanService --> LichPhongVanRepository
ThongBaoService --> ThongBaoRepository
DashboardService --> DonUngTuyenRepository
MatchingService --> MatchingRepository
KyNangService --> KyNangRepository

SecurityConfig --> JwtAuthenticationFilter
JwtAuthenticationFilter --> JwtTokenProvider
JwtAuthenticationFilter --> CustomUserDetailsService
CustomUserDetailsService --> TaiKhoanRepository
CustomUserDetails --> TaiKhoan
JwtTokenProvider --> TimeProvider

CosineSimilarityStrategy ..|> SkillMatchingStrategy
KeywordMatchingStrategy ..|> SkillMatchingStrategy
MatchingService --> SkillMatchingStrategy
CosineSimilarityStrategy --> TimeProvider
KeywordMatchingStrategy --> TimeProvider
SystemTimeProvider ..|> TimeProvider

NganhNgheController ..> NganhNgheEnum
KhuVucController ..> KhuVucEnum

@enduml
