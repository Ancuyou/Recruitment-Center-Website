@startuml
actor "QuanTriVien" as Admin
participant "KiemDuyetTinPage" as View
participant "KiemDuyetTinController" as Controller
participant "KiemDuyetTinService" as Service
participant "TinTuyenDungRepository" as Repo
participant "ThongBaoService" as NotificationService
database "MySQL" as DB

Admin -> View : Mo danh sach tin cho kiem duyet
View -> Controller : getPendingPosts()
Controller -> Service : getPendingPosts()
Service -> Repo : findPendingPosts()
Repo -> DB : SELECT * FROM tin_tuyen_dung WHERE trang_thai = 'PENDING'
DB --> Repo : pending posts
Repo --> Service : pending posts
Service --> Controller : pending posts
Controller --> View : show pending posts

Admin -> View : Chon tin de kiem duyet
View -> Controller : reviewPost(postId)
Controller -> Service : reviewPost(postId)
Service -> Repo : findById(postId)
Repo -> DB : SELECT * FROM tin_tuyen_dung WHERE id = ?
DB --> Repo : post detail
Repo --> Service : post detail
Service --> Controller : post detail
Controller --> View : show post detail

alt Tin vi pham chinh sach
    Admin -> View : Dong tin va nhap ly do
    View -> Controller : closePost(postId, reason)
    Controller -> Service : closePost(postId, reason, adminId)
    Service -> Repo : updateStatus(postId, CLOSED)
    Repo -> DB : UPDATE tin_tuyen_dung SET trang_thai = 'CLOSED', ly_do = ...
    DB --> Repo : updated
    Repo --> Service : success
    Service -> NotificationService : notifyRecruiter(postId, "Tin da bi dong")
    NotificationService -> DB : INSERT INTO thong_bao ...
    DB --> NotificationService : sent
    NotificationService --> Service : success
    Service --> Controller : close success
    Controller --> View : thong bao da dong tin
else Tin khong vi pham
    Admin -> View : Chi xem thong tin, khong thay doi trang thai
end
@enduml