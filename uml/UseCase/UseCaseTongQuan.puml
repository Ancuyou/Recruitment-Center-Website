UV -[#2E7D32]-> UC12

' NHA TUYEN DUNG
NTD -[#1565C0]-> UC01
NTD -[#1565C0]-> UC02
NTD -[#1565C0]-> UC03
NTD -[#1565C0]-> UC04
NTD -[#1565C0]-> UC05
NTD -[#1565C0]-> UC13
