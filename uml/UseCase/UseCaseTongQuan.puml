@startuml UC00_TongQuan
left to right direction
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam nodesep 80
skinparam ranksep 260
skinparam linetype ortho

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #E65100
  FontSize 12
}
skinparam package {
  BackgroundColor #FAFAFA
  BorderColor #90A4AE
  FontSize 12
  FontStyle bold
  Padding 20
}
skinparam rectangle {
  BackgroundColor #EDE7F6
  BorderColor #5E35B1
  FontSize 14
  FontStyle bold
}

actor "Ung vien"       as UV
actor "Nha tuyen dung" as NTD
actor "Quan tri vien"  as ADMIN

UV  -[hidden]d-> NTD
NTD -[hidden]d-> ADMIN

rectangle "He thong Tuyen dung Truc tuyen" {

  package "Use case dung chung" {
    usecase "UC01\nXem va tim kiem viec lam"          as UC01
    usecase "UC02\nTra cuu danh muc he thong"         as UC02
    usecase "UC03\nDang ky"                           as UC03
    usecase "UC04\nDang nhap"                         as UC04
    usecase "UC05\nKhoi phuc tai khoan"               as UC05
  }

  package "Use case rieng - Ung vien" {
    usecase "UC06\nQuan ly ho so ca nhan"             as UC06
    usecase "UC07\nQuan ly CV"                        as UC07
    usecase "UC08\nUng tuyen va theo doi trang thai" as UC08
    usecase "UC09\nXem lich phong van ca nhan"       as UC09
    usecase "UC10\nNhan thong bao ung vien"          as UC10
    usecase "UC11\nXem dashboard ung vien"           as UC11
    usecase "UC12\nXem goi y viec lam / tinh match score" as UC12
  }

  package "Use case rieng - Nha tuyen dung" {
    usecase "UC13\nQuan ly cong ty"                            as UC13
    usecase "UC14\nQuan ly tin tuyen dung"            as UC14
    usecase "UC15\nXu ly don ung tuyen"               as UC15
    usecase "UC16\nQuan ly lich phong van"            as UC16
    usecase "UC17\nNhan thong bao nha tuyen dung"    as UC17
    usecase "UC18\nXem dashboard nha tuyen dung"     as UC18
    usecase "UC19\nXem goi y ung vien / tinh match score" as UC19
  }

  package "Use case rieng - Quan tri vien" {
    usecase "UC20\nQuan ly ky nang he thong"          as UC20
    usecase "UC21\nKiem duyet va dong tin tuyen dung" as UC21
    usecase "UC22\nQuan ly cong ty"                   as UC22
    usecase "UC23\nQuan ly nguoi dung"                as UC23
    usecase "UC24\nXem dashboard quan tri tong hop"  as UC24
  }
}

' UNG VIEN
UV -[#2E7D32]-> UC01
