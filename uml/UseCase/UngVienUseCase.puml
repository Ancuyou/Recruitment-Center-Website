@startuml UC01_UngVien
left to right direction
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam nodesep 70
skinparam ranksep 260
skinparam linetype ortho

skinparam usecase {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
  FontSize 12
}
skinparam package {
  BackgroundColor #F9FBE7
  BorderColor #9CCC65
  FontSize 12
  FontStyle bold
  Padding 18
}
skinparam rectangle {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
  FontSize 14
  FontStyle bold
}

actor "Ung vien" as UV

rectangle "He thong Tuyen dung - Goc nhin Ung vien" {

  package "Use case dung chung" {
    usecase "UC01\nXem / Tim kiem viec lam"           as UC01
    usecase "UC02\nTra cuu danh muc he thong"         as UC02
    usecase "UC03\nDang ky"                           as UC03
    usecase "UC04\nDang nhap"                         as UC04
    usecase "UC05\nKhoi phuc tai khoan"               as UC05
  }

  package "Use case rieng - Ung vien" {
    usecase "UC06\nQuan ly ho so ca nhan"             as UC06
    usecase "UC07\nQuan ly CV"                        as UC07
    usecase "UC08\nUng tuyen & Theo doi trang thai"   as UC08
    usecase "UC09\nXem lich phong van"                as UC09
    usecase "UC10\nNhan thong bao"                    as UC10
    usecase "UC11\nXem Dashboard"                     as UC11
    usecase "UC12\nXem goi y viec lam / Match score"  as UC12
  }
}

UV -[#2E7D32]-> UC01
UV -[#2E7D32]-> UC02
UV -[#2E7D32]-> UC03
UV -[#2E7D32]-> UC04
UV -[#2E7D32]-> UC05
UV -[#2E7D32]-> UC06
UV -[#2E7D32]-> UC07
UV -[#2E7D32]-> UC08
UV -[#2E7D32]-> UC09
UV -[#2E7D32]-> UC10
UV -[#2E7D32]-> UC11
UV -[#2E7D32]-> UC12

@enduml