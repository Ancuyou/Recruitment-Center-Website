@startuml UC03_Admin
left to right direction
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam nodesep 70
skinparam ranksep 260
skinparam linetype ortho

skinparam usecase {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
  FontSize 12
}
skinparam package {
  BackgroundColor #FDF6F9
  BorderColor #F48FB1
  FontSize 12
  FontStyle bold
  Padding 18
}
skinparam rectangle {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
  FontSize 14
  FontStyle bold
}

actor "Quan tri vien" as ADMIN

rectangle "He thong Tuyen dung - Goc nhin Quan tri vien" {

  package "Use case dung chung" {
    usecase "UC01\nXem va tim kiem viec lam"          as UC01
    usecase "UC02\nTra cuu danh muc he thong"         as UC02
    usecase "UC04\nDang nhap"                         as UC04
    usecase "UC05\nKhoi phuc tai khoan"               as UC05
  }

  package "Use case rieng - Quan tri vien" {
    usecase "UC20\nQuan ly ky nang he thong"          as UC20
    usecase "UC21\nKiem duyet va dong tin tuyen dung" as UC21
    usecase "UC22\nQuan ly cong ty"                   as UC22
    usecase "UC23\nQuan ly nguoi dung"                as UC23
    usecase "UC24\nXem dashboard quan tri tong hop"  as UC24
  }
}

' Admin chi lien ket Dang nhap + Khoi phuc tai khoan o nhom dung chung
ADMIN -[#880E4F]-> UC04
ADMIN -[#880E4F]-> UC05
ADMIN -[#880E4F]-> UC20
ADMIN -[#880E4F]-> UC21
ADMIN -[#880E4F]-> UC22
ADMIN -[#880E4F]-> UC23
ADMIN -[#880E4F]-> UC24
ADMIN -[#880E4F]-> UC01
ADMIN -[#880E4F]-> UC02

@enduml