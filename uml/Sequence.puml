@startuml
actor Staff
participant "ReturnBookPanel" as View
participant "LoanController" as Controller
participant "LoanService" as Service
database "MySQL / JPA" as DB

Staff -> View : Enter loan code
View -> Controller : getLoanByCode(code)
Controller -> Service : getLoanByCode(code)
Service -> DB : Query loan + details
DB --> Service : Loan
Service --> Controller : Loan
Controller --> View : Loan details

Staff -> View : Select loan detail and return qty
Staff -> View : Click Return
View -> Controller : returnBook(loanDetailId, qty, date)
Controller -> Service : returnBook(...)
Service -> DB : Begin transaction
Service -> DB : Find LoanDetail
Service -> DB : Validate remaining quantity
Service -> DB : Update LoanDetail.returnedQuantity
Service -> DB : Update LoanDetail.returnDate
Service -> DB : Update Book.availableQuantity
Service -> DB : Recalculate Loan.status
Service -> DB : Commit
Service --> Controller : Updated Loan
Controller --> View : Updated Loan
View --> Staff : Show success
@enduml