@startuml
start
:Open Return Book Panel;
:Enter loan code;
:Search loan;
if (Loan found?) then (Yes)
  :Display loan details;
  :Select loan detail row;
  :Enter return quantity and return date;
  if (Return quantity valid?) then (Yes)
    :Update returnedQuantity;
    :Update returnDate;
    :Increase availableQuantity of book;
    :Recalculate loan status;
    :Commit transaction;
    :Show success message;
  else (No)
    :Show invalid quantity error;
  endif
else (No)
  :Show loan not found error;
endif
stop
@enduml