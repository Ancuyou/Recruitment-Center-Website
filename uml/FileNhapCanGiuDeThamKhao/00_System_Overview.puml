@startuml Tong_Quan_UseCase_HeThong
left to right direction

actor "Khach" as KHACH
actor "Ung vien" as UV
actor "Nha tuyen dung" as NTD
actor "Quan tri vien" as ADMIN

rectangle "He thong tuyen dung" {
  usecase "Xac thuc tai khoan" as UC_AUTH
  usecase "Quan ly ho so ca nhan" as UC_PROFILE
  usecase "Quan ly cong ty" as UC_COMPANY
  usecase "Quan ly tin tuyen dung" as UC_JOB_MGMT
  usecase "Tim kiem va xem tin tuyen dung" as UC_JOB_VIEW
  usecase "Quan ly ho so CV" as UC_CV
  usecase "Quan ly ky nang" as UC_SKILL
  usecase "Quan ly don ung tuyen" as UC_APP
  usecase "Quan ly phong van" as UC_INTERVIEW
  usecase "Quan ly thong bao" as UC_NOTIFY
  usecase "Xem bang dieu khien" as UC_DASH
  usecase "Goi y va danh gia do phu hop" as UC_MATCH
  usecase "Tra cuu danh muc" as UC_REF
  usecase "Quan ly tai khoan nguoi dung" as UC_USER_ADMIN

  usecase "Dang ky ung vien" as UC_AUTH_CANDIDATE_REGISTER
  usecase "Dang ky nha tuyen dung" as UC_AUTH_RECRUITER_REGISTER
  usecase "Dang nhap" as UC_AUTH_LOGIN
  usecase "Dang xuat" as UC_AUTH_LOGOUT
  usecase "Lam moi token" as UC_AUTH_REFRESH
  usecase "Quen mat khau" as UC_AUTH_FORGOT
  usecase "Dat lai mat khau" as UC_AUTH_RESET
  usecase "Xac thuc email" as UC_AUTH_VERIFY

  usecase "Xem thong tin ca nhan" as UC_PROFILE_VIEW
  usecase "Cap nhat ho so ca nhan" as UC_PROFILE_UPDATE
  usecase "Doi mat khau" as UC_PROFILE_PASSWORD
  usecase "Cap nhat anh dai dien" as UC_PROFILE_AVATAR

  usecase "Dang tin tuyen dung" as UC_JOB_CREATE
  usecase "Cap nhat tin tuyen dung" as UC_JOB_UPDATE
  usecase "Dong tin tuyen dung" as UC_JOB_CLOSE
  usecase "Xem tin da dang" as UC_JOB_MY
  usecase "Xem thong ke tin" as UC_JOB_STATS
  usecase "Quan ly khu vuc tuyen" as UC_JOB_LOC
  usecase "Quan ly ky nang yeu cau" as UC_JOB_SKILL_REQ

  usecase "Xem danh sach tin" as UC_JOB_LIST
  usecase "Tim kiem tin" as UC_JOB_SEARCH
  usecase "Xem chi tiet tin" as UC_JOB_DETAIL

  usecase "Tao CV" as UC_CV_CREATE
  usecase "Cap nhat CV" as UC_CV_UPDATE
  usecase "Xoa CV" as UC_CV_DELETE
  usecase "Chon CV mac dinh" as UC_CV_DEFAULT
  usecase "Tai tep CV" as UC_CV_UPLOAD
  usecase "Quan ly chi tiet CV" as UC_CV_DETAIL_MGMT
  usecase "Quan ly ky nang CV" as UC_CV_SKILL_MGMT

  usecase "Xem danh sach ky nang" as UC_SKILL_LIST
  usecase "Tim kiem ky nang" as UC_SKILL_SEARCH
  usecase "Tao ky nang" as UC_SKILL_CREATE
  usecase "Cap nhat ky nang" as UC_SKILL_UPDATE
  usecase "Xoa ky nang" as UC_SKILL_DELETE

  usecase "Nop don ung tuyen" as UC_APP_SUBMIT
  usecase "Xem don da nop" as UC_APP_CANDIDATE_LIST
  usecase "Xem don theo tin" as UC_APP_RECRUITER_LIST
  usecase "Xem chi tiet don" as UC_APP_DETAIL
  usecase "Cap nhat trang thai don" as UC_APP_STATUS
  usecase "Tu choi don" as UC_APP_REJECT
  usecase "Xem lich su trang thai" as UC_APP_HISTORY
  usecase "Xem anh CV dinh kem" as UC_APP_CV_SNAPSHOT

  usecase "Tao lich phong van" as UC_INTERVIEW_CREATE
  usecase "Xem lich phong van" as UC_INTERVIEW_VIEW
  usecase "Cap nhat lich phong van" as UC_INTERVIEW_UPDATE
  usecase "Huy lich phong van" as UC_INTERVIEW_CANCEL
  usecase "Doi lich phong van" as UC_INTERVIEW_RESCHEDULE

  usecase "Xem danh sach thong bao" as UC_NOTIFY_LIST
  usecase "Danh dau da doc" as UC_NOTIFY_READ_ONE
  usecase "Danh dau tat ca da doc" as UC_NOTIFY_READ_ALL
  usecase "Dem thong bao chua doc" as UC_NOTIFY_COUNT

  usecase "Xem dashboard ung vien" as UC_DASH_UV
  usecase "Xem dashboard nha tuyen dung" as UC_DASH_NTD

  usecase "Goi y cong viec phu hop" as UC_MATCH_JOB
  usecase "Goi y ung vien phu hop" as UC_MATCH_CANDIDATE
  usecase "Tinh diem phu hop" as UC_MATCH_SCORE

  usecase "Xem danh sach nganh nghe" as UC_REF_INDUSTRY
  usecase "Xem danh sach khu vuc" as UC_REF_LOCATION

  usecase "Xem thong tin tai khoan theo ID" as UC_USER_ADMIN_VIEW
}

KHACH --> UC_AUTH
KHACH --> UC_JOB_VIEW
KHACH --> UC_REF

UV --> UC_AUTH
UV --> UC_PROFILE
UV --> UC_JOB_VIEW
UV --> UC_CV
UV --> UC_APP
UV --> UC_INTERVIEW
UV --> UC_NOTIFY
UV --> UC_DASH
UV --> UC_MATCH
UV --> UC_SKILL
UV --> UC_REF

NTD --> UC_AUTH
