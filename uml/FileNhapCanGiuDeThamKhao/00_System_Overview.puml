NTD --> UC_JOB_MGMT
NTD --> UC_JOB_VIEW
NTD --> UC_APP
NTD --> UC_INTERVIEW
NTD --> UC_NOTIFY
NTD --> UC_DASH
NTD --> UC_MATCH
NTD --> UC_SKILL
NTD --> UC_REF

ADMIN --> UC_AUTH
ADMIN --> UC_COMPANY
ADMIN --> UC_JOB_MGMT
ADMIN --> UC_SKILL
ADMIN --> UC_USER_ADMIN

UC_AUTH ..> UC_AUTH_CANDIDATE_REGISTER : <<include>>
UC_AUTH ..> UC_AUTH_RECRUITER_REGISTER : <<include>>
