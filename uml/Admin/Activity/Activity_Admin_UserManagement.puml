@startuml Activity_Admin_UserManagement
title Quản Trị - Quản Lý Người Dùng

start

:Click "Quản lý người dùng";

:Chọn loại người dùng (ứng viên/nhà tuyển dụng);
:Xem danh sách;

:Tìm kiếm theo tên/email;

:Chọn người dùng;
:Xem thông tin tài khoản;

if (Phát hiện vi phạm?) then (Có)
  :Khóa tài khoản;
  :Gửi thông báo lý do;
else (Không)
  :Kiểm tra hoạt động;
endif

if (Yêu cầu mở khóa?) then (Có)
  :Xác nhận yêu cầu;
  :Mở khóa tài khoản;
else (Không)
endif

stop

@enduml
