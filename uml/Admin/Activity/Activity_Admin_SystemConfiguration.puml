@startuml Activity_Admin_SystemConfiguration
title Quản Trị - Cấu Hình Hệ Thống

start

:Click "Cấu hình hệ thống";

:Quản lý danh sách ngành;

partition "Quản Lý Ngành" {
  :Tạo ngành mới;
  :Sửa ngành hiện có;
  :Xóa ngành;
}

:Quản lý danh sách khu vực;

partition "Quản Lý Khu Vực" {
  :Tạo khu vực mới;
  :Sửa khu vực;
  :Xóa khu vực;
}

:Quản lý danh sách kỹ năng;

partition "Quản Lý Kỹ Năng" {
  :Tạo kỹ năng mới;
  :Sửa kỹ năng;
  :Xóa kỹ năng;
}

:Quản lý loại hình làm việc;

stop

@enduml
