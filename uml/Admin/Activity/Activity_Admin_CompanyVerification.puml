@startuml Activity_Admin_CompanyVerification
title Quản Trị - Xác Thực Công Ty

start

:Click "Xác thực công ty";

:Xem danh sách công ty chờ xác thực;

:Chọn công ty;

:Xem thông tin\n(tên, địa chỉ, mã số thuế);

:Kiểm tra mã số thuế;

if (Hợp lệ?) then (Có)
  :Xác thực công ty;
  :Gửi thông báo xác thực;
  :Công ty được phép đăng tin;
else (Không)
  :Từ chối công ty;
  :Gửi lý do từ chối;
endif

stop

@enduml
