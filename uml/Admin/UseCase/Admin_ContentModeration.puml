@startuml Admin_ContentModeration

title Admin - Content Moderation (Module D)

actor Admin as "🔐 Admin"

rectangle "JOB POSTINGS" {
    usecase "List Job\nPostings" as CM1
    usecase "Review Job\nDetails" as CM2
    usecase "Approve Posting" as CM3
    usecase "Reject Posting" as CM4
}

rectangle "APPLICATIONS" {
    usecase "List\nApplications" as CM5
    usecase "Review\nApplication" as CM6
    usecase "Flag Suspicious\nApplication" as CM7
}

Admin --> CM1: 1. List job postings
CM1 --> CM2: Review details
CM2 --> CM3: 2. Approve
CM2 --> CM4: 3. Reject

Admin --> CM5: 4. List applications
CM5 --> CM6: Review application
CM6 --> CM7: 5. Flag suspicious

note right of CM1
  **Priority:** P1 (Important)
  **Status:** Need Validation
end note

@enduml
