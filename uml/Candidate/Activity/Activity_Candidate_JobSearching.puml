@startuml Activity_Candidate_JobSearching
title Ứng Viên - Tìm Kiếm & Nộp Đơn

start

:Nhấp "Tìm việc làm";
:Xem danh sách công việc;

:Áp dụng bộ lọc (nếu cần);
:Chọn: ngành, khu vực, mức lương;
:Filter danh sách;

partition "Với mỗi công việc" {
  :Click vào công việc;
  :Xem chi tiết job\n(mô tả, yêu cầu, địa điểm);
  
  :Hệ thống tính toán Match Score;
  :So sánh CV với yêu cầu job;
  :Hiển thị "Độ phù hợp: XX%";
  
  if (Quan tâm?) then (Có)
    :Click "Nộp đơn";
    :Chọn CV để nộp;
    :Viết cover letter (tùy chọn);
    :Click "Nộp";
    
    if (Chưa nộp trước?) then (Đúng)
      :Lưu đơn ứng tuyển;
      :Thông báo "Nộp thành công";
    else (Đã nộp)
      :Hiển thị lỗi "Đã nộp đơn này";
    endif
  else (Không)
    :Tiếp tục tìm kiếm;
  endif
}

stop

@enduml
