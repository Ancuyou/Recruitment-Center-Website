@startuml Activity_Candidate_Authentication
title Ứng Viên - Đăng Ký & Đăng Nhập

start

:Truy cập ứng dụng;

if (Đã đăng ký?) then (Không)
  :Nhấp "Đăng ký";
  :Nhập email, password, tên;
  :Validate dữ liệu;
  :Kiểm tra email đã tồn tại?;
  if (Email unique?) then (Có)
    :Tạo tài khoản;
    :Gửi email xác nhận;
    :Nhận email & click link;
    :Xác nhận email thành công;
  else (Không)
    :Hiển thị lỗi "Email đã tồn tại";
    stop
  endif
else (Có)
endif

:Nhấp "Đăng nhập";
:Nhập email & password;
:Validate input;

:Gửi request đến server;

if (Email tồn tại?) then (Có)
  if (Password đúng?) then (Có)
    :Tạo JWT token;
    :Trả lại token cho client;
    :Lưu token vào localStorage;
    :Redirect tới Dashboard;
  else (Không)
    :Hiển thị lỗi "Mật khẩu sai";
    stop
  endif
else (Không)
  :Hiển thị lỗi "Email không tồn tại";
  stop
endif

stop

@enduml
